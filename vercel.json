{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd js/code && npm install && npm run build",
  "outputDirectory": "js/code/dist",
  "installCommand": "cd js/code && npm install",
  "cleanUrls": true,
  "routes": [
    { "src": "^/后台登录页(?:\\.html)?$", "dest": "/login" },
    { "src": "^/执行机构工作台(?:\\.html)?$", "dest": "/agency-dashboard" },
    { "src": "^/活动提报表单页(?:\\.html)?$", "dest": "/activity-proposal-form" },
    { "src": "^/管理员控制台(?:\\.html)?$", "dest": "/admin-dashboard" },
    { "src": "^/活动审核管理页(?:\\.html)?$", "dest": "/activity-audit-list" },
    { "src": "^/活动详情审核页(?:\\.html)?$", "dest": "/activity-detail-view" },
    { "src": "^/门户首页(?:\\.html)?$", "dest": "/home" },
    { "src": "^/活动详情页(?:\\.html)?$", "dest": "/activity-detail" },
    { "src": "^/报名成功反馈页(?:\\.html)?$", "dest": "/enrollment-success" },
    { "src": "^/机构活动管理(?:\\.html)?$", "dest": "/agency-activity-list" },
    { "src": "^/全量活动管理(?:\\.html)?$", "dest": "/admin-all-activities" },
    { "src": "^/报名数据详情(?:\\.html)?$", "dest": "/enrollment-data-detail" },
    { "src": "^/用户与执行机构管理(?:\\.html)?$", "dest": "/user-account-management" },
    { "src": "^/系统配置中心(?:\\.html)?$", "dest": "/system-config-center" },
    { "src": "^/活动高级内容编辑页(?:\\.html)?$", "dest": "/activity-advanced-editor" },
    { "src": "^/往期活动回顾发布页(?:\\.html)?$", "dest": "/activity-past-archive-manager" },
    { "src": "^/用户注册页面(?:\\.html)?$", "dest": "/page-2651559" },
    { "src": "^/用户信息详情(?:\\.html)?$", "dest": "/page-2651560" },
    { "src": "^/已上架活动列表(?:\\.html)?$", "dest": "/page-2659759" },

    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "rewrites": [
    { "source": "/后台登录页", "destination": "/login" },
    { "source": "/后台登录页.html", "destination": "/login" },
    { "source": "/执行机构工作台", "destination": "/agency-dashboard" },
    { "source": "/执行机构工作台.html", "destination": "/agency-dashboard" },
    { "source": "/活动提报表单页", "destination": "/activity-proposal-form" },
    { "source": "/活动提报表单页.html", "destination": "/activity-proposal-form" },
    { "source": "/管理员控制台", "destination": "/admin-dashboard" },
    { "source": "/管理员控制台.html", "destination": "/admin-dashboard" },
    { "source": "/活动审核管理页", "destination": "/activity-audit-list" },
    { "source": "/活动审核管理页.html", "destination": "/activity-audit-list" },
    { "source": "/活动详情审核页", "destination": "/activity-detail-view" },
    { "source": "/活动详情审核页.html", "destination": "/activity-detail-view" },
    { "source": "/门户首页", "destination": "/home" },
    { "source": "/门户首页.html", "destination": "/home" },
    { "source": "/活动详情页", "destination": "/activity-detail" },
    { "source": "/活动详情页.html", "destination": "/activity-detail" },
    { "source": "/报名成功反馈页", "destination": "/enrollment-success" },
    { "source": "/报名成功反馈页.html", "destination": "/enrollment-success" },
    { "source": "/机构活动管理", "destination": "/agency-activity-list" },
    { "source": "/机构活动管理.html", "destination": "/agency-activity-list" },
    { "source": "/全量活动管理", "destination": "/admin-all-activities" },
    { "source": "/全量活动管理.html", "destination": "/admin-all-activities" },
    { "source": "/报名数据详情", "destination": "/enrollment-data-detail" },
    { "source": "/报名数据详情.html", "destination": "/enrollment-data-detail" },
    { "source": "/用户与执行机构管理", "destination": "/user-account-management" },
    { "source": "/用户与执行机构管理.html", "destination": "/user-account-management" },
    { "source": "/系统配置中心", "destination": "/system-config-center" },
    { "source": "/系统配置中心.html", "destination": "/system-config-center" },
    { "source": "/活动高级内容编辑页", "destination": "/activity-advanced-editor" },
    { "source": "/活动高级内容编辑页.html", "destination": "/activity-advanced-editor" },
    { "source": "/往期活动回顾发布页", "destination": "/activity-past-archive-manager" },
    { "source": "/往期活动回顾发布页.html", "destination": "/activity-past-archive-manager" },
    { "source": "/用户注册页面", "destination": "/page-2651559" },
    { "source": "/用户注册页面.html", "destination": "/page-2651559" },
    { "source": "/用户信息详情", "destination": "/page-2651560" },
    { "source": "/用户信息详情.html", "destination": "/page-2651560" },
    { "source": "/已上架活动列表", "destination": "/page-2659759" },
    { "source": "/已上架活动列表.html", "destination": "/page-2659759" }
  ]
}
