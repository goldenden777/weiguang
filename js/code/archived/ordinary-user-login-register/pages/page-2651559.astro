
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import PhoneRegisterForm from '@/components/page-2651559/PhoneRegisterForm.vue'
---

<BaseLayout title="用户注册 - 微光公益">
  <CommonHeader client:load variant="guest" mode="mobile" />
  
  <main class="flex-1 flex flex-col bg-background">
    <!-- Hero Section -->
    <div class="bg-gradient-radial-at-t from-primary/5 to-transparent py-12 px-6 text-center">
      <h1 class="text-2xl font-bold tracking-tight mb-2">加入微光</h1>
      <p class="text-sm text-muted-foreground leading-relaxed">用手机号快速注册，开启公益之旅</p>
    </div>

    <!-- Form Container -->
    <div class="flex-1 px-6 py-4">
      <PhoneRegisterForm client:load />
    </div>

    <!-- Footer Links -->
    <div class="px-6 py-8 text-center border-t border-border bg-muted/10">
      <p class="text-xs text-muted-foreground mb-3">
        注册即表示同意以下条款
      </p>
      <div class="flex items-center justify-center gap-3 text-xs">
        <a href="./home.html" class="text-primary hover:underline">
          服务条款
        </a>
        <span class="text-border">|</span>
        <a href="./home.html" class="text-primary hover:underline">
          隐私政策
        </a>
      </div>
    </div>
  </main>

<CommonFooter client:load variant="simple" layout="mobile" />
</BaseLayout>
