---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  mode?: 'mobile' | 'desktop';
}

const { 
  title = 'Project', 
  description = 'Built with Astro',
  mode = 'mobile'
} = Astro.props;

const isMobile = mode === 'mobile';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
<body class:list={[
    "min-h-screen",
    isMobile ? "bg-slate-100 dark:bg-slate-950" : "bg-slate-50"
  ]}>
    {isMobile ? (
      /* Mobile Container Emulator */
      <div class="mx-auto w-full max-w-[430px] min-h-screen bg-background shadow-2xl relative overflow-x-hidden border-x border-border/50 flex flex-col font-sans">
        <slot />
        <!-- Padding for sticky elements like tab bar -->
        <div class="h-16 shrink-0"></div>
      </div>
    ) : (
      /* Desktop Full Width Layout */
      <div class="w-full min-h-screen bg-background flex flex-col font-sans">
        <slot />
      </div>
    )}
    <script is:inline define:vars={{ isDev: import.meta.env.DEV }}>
      (function(){ if (typeof window === 'undefined' || !isDev) return; if (window.location.protocol === 'file:') { const el = document.createElement('div'); el.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#f59e0b;color:#000;padding:8px;text-align:center;z-index:99999;font-size:12px;'; el.textContent = '请使用 npm run dev 后通过 http://localhost:4321 访问本页，否则脚本与样式可能无法加载。'; document.body.prepend(el); } })();
    </script>
  </body>
</html>
