
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Card, CardContent } from '@/components/ui/card'
---

<BaseLayout title="页面建设中 - 微光公益">
  <div class="min-h-screen flex items-center justify-center bg-gradient-radial-at-t from-primary/5 to-background p-4">
    <Card class="max-w-md w-full">
      <CardContent class="pt-6 text-center space-y-4">
        <div class="w-16 h-16 mx-auto rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
        </div>
        <h1 class="text-2xl font-semibold">页面建设中</h1>
        <p class="text-muted-foreground">此页面正在开发中,敬请期待</p>
        <a 
          href="./home.html" 
          class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          返回首页
        </a>
      </CardContent>
    </Card>
  </div>
</BaseLayout>
