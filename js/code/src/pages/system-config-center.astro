
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import AppSidebarLayout from '@/components/common/AppSidebarLayout.vue'
import PageHeader from '@/components/common/PageHeader.vue'
import SystemConfigCenter from '@/components/system-config-center/SystemConfigCenter.vue'
import AuthGuard from '@/components/auth/AuthGuard.vue'
---

<BaseLayout title="系统配置中心 - 微光公益" mode="desktop">
  <AuthGuard client:load required-role="admin" />
  <AppSidebarLayout client:load variant="admin" headerHeight="64px">
    <div class="flex-1 flex flex-col min-h-screen">
      <PageHeader 
        title="系统配置中心"
        breadcrumbs={[
          { label: '工作台', href: './admin-dashboard.html' },
          { label: '系统配置中心' }
        ]}
      />
      <div class="flex-1 p-6 lg:p-8 bg-slate-50/50">
        <SystemConfigCenter client:load />
      </div>
    </div>
  </AppSidebarLayout>
</BaseLayout>
