
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CommonHeader from '@/components/common/CommonHeader.vue'
import CommonFooter from '@/components/common/CommonFooter.vue'
import SuccessCard from '@/components/enrollment-success/SuccessCard.vue'
import EnrollmentGuide from '@/components/enrollment-success/EnrollmentGuide.vue'
---

<BaseLayout title="报名成功 - 微光公益" mode="mobile">
  <CommonHeader client:load variant="guest" mode="mobile" />
  
  <main class="flex-1">
    <div class="px-4 py-8 space-y-6">
      <!-- Success Card -->
      <SuccessCard client:load />
      
      <!-- Guidance Section -->
      <EnrollmentGuide client:load />
    </div>
  </main>

  <CommonFooter client:load variant="simple" layout="mobile" />
</BaseLayout>
