---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AppSidebarLayout from '@/components/common/AppSidebarLayout.vue'
import PageHeader from '@/components/common/PageHeader.vue'
import ContentManagement from '@/components/content-management/ContentManagement.vue'
import AuthGuard from '@/components/auth/AuthGuard.vue'
---

<BaseLayout title="内容管理 - 微光公益" mode="desktop">
  <AuthGuard client:load required-role="admin" />
  <AppSidebarLayout client:load variant="admin" headerHeight="64px">
    <div class="flex-1 flex flex-col min-h-screen bg-slate-50/50">
      <PageHeader
        title="内容管理"
        breadcrumbs={[
          { label: '工作台', href: './admin-dashboard.html' },
          { label: '内容管理' }
        ]}
      />
      <main class="flex-1 p-6">
        <ContentManagement client:load />
      </main>
    </div>
  </AppSidebarLayout>
</BaseLayout>
