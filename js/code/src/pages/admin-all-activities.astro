
---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AppSidebarLayout from '@/components/common/AppSidebarLayout.vue'
import PageHeader from '@/components/common/PageHeader.vue'
import AdminActivityContent from '@/components/admin-all-activities/AdminActivityContent.vue'
import AuthGuard from '@/components/auth/AuthGuard.vue'
---

<BaseLayout title="全量活动管理 - 微光公益" mode="desktop">
  <AuthGuard client:load required-role="admin" />
  <AppSidebarLayout client:load variant="admin">
    <main class="flex-1 flex flex-col bg-slate-50/50">
      <PageHeader 
        title="全量活动管理"
        breadcrumbs={[
          { label: '工作台', href: './admin-dashboard.html' },
          { label: '全量活动管理' }
        ]}
      >
        <template slot="actions">
          <a href="./activity-proposal-form.html">
            <button class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
              创建新活动
            </button>
          </a>
        </template>
      </PageHeader>
      <AdminActivityContent client:load />
    </main>
  </AppSidebarLayout>
</BaseLayout>
